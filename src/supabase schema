-- 19. Room Categories (types of rooms offered to guests)
------------------------------------------------------------
create table public.room_categories (
    id uuid primary key default gen_random_uuid(),
    name text not null,
    description text,
    image_url text, -- Featured image
    hover_image_url text, -- Hover preview
    price numeric(12,2) not null,
    occupancy integer not null,
    amenities jsonb,               -- optional list of amenity ids
    is_featured boolean default false,
    sort_order integer not null default 0,
    created_at timestamp with time zone default now(),
    updated_at timestamp with time zone default now()
);

-- Gallery for room categories
create table public.room_category_images (
    id uuid primary key default gen_random_uuid(),
    category_id uuid references public.room_categories(id) on delete cascade,
    image_url text not null,
    sort_order integer not null default 0,
    created_at timestamp with time zone default now()
);

alter table public.room_category_images enable row level security;
create policy "public_read_room_cat_images" on public.room_category_images for select using (true);
create policy "admin_write_room_cat_images" on public.room_category_images for all using (auth.role() = 'authenticated') with check (auth.role() = 'authenticated');
create index idx_room_categories_name on public.room_categories (name);

