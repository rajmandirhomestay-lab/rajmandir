-- 20. Physical Rooms (inventory of actual rooms)
------------------------------------------------------------
create type public.room_status as enum ('available', 'occupied', 'cleaning', 'maintenance');

create table public.physical_rooms (
    id uuid primary key default gen_random_uuid(),
    category_id uuid references public.room_categories(id) on delete cascade,
    room_number text not null unique,
    status public.room_status default 'available',
    sort_order integer not null default 0,
    created_at timestamp with time zone default now(),
    updated_at timestamp with time zone default now()
);
create index idx_physical_rooms_number on public.physical_rooms (room_number);
create index idx_physical_rooms_status on public.physical_rooms (status);

-- Triggers for updated_at
create trigger trg_room_categories_upd before update on public.room_categories
for each row execute function public.update_timestamp();

create trigger trg_physical_rooms_upd before update on public.physical_rooms
for each row execute function public.update_timestamp();

-- RLS for new tables
alter table public.room_categories enable row level security;
alter table public.physical_rooms enable row level security;

-- Public read access (guests can see categories)
create policy "public_read_room_categories"
  on public.room_categories
  for select
  using (true);

-- Admin write access for room_categories
create policy "admin_write_room_categories"
  on public.room_categories
  for all
  using (auth.role() = 'authenticated')
  with check (auth.role() = 'authenticated');

-- Public read access for physical_rooms
create policy "public_read_physical_rooms"
  on public.physical_rooms
  for select
  using (true);

-- Admin write access for physical_rooms
create policy "admin_write_physical_rooms"
  on public.physical_rooms
  for all
  using (auth.role() = 'authenticated')
  with check (auth.role() = 'authenticated');

